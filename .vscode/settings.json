{
    // PlatformIO settings
    "platformio-ide.activateOnlyOnPlatformIOProject": true,

    // C/C++ IntelliSense - use PlatformIO configuration
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",

    // Editor settings for embedded C++
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.formatOnSave": false,

    // File associations
    "files.associations": {
        "*.h": "cpp",
        "*.cpp": "cpp",
        "*.ino": "cpp"
    },

    // Exclude build artifacts from file explorer
    "files.exclude": {
        "**/.pio": true,
        "**/.git": false
    },

    // Search exclusions
    "search.exclude": {
        "**/.pio": true
    }
}
